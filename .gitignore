# =============================================================================
# SideX .gitignore
# =============================================================================

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Build output ─────────────────────────────────────────────────────────────
dist/
out/
build/
# @sidex/build is a workspace package, not build output.
!packages/build/
*.tsbuildinfo

# ── Rust / Cargo ─────────────────────────────────────────────────────────────
**/target/

# ── WASM build artifacts (wasm-pack output) ──────────────────────────────────
**/pkg/

# Generated wasm artifacts (built by build:wasm)
apps/workbench/public/wasm/
packages/build/test/fixtures/wasm-tfidf/

# ── Extensions (auto-installed on first dev/build via npm run setup) ──────────
/extensions/

# ── Cargo.lock for library crates ───────────────────────────────────────────
# Library lock files should not be committed (Cargo best practice).
# The application lock (apps/desktop/Cargo.lock) IS committed.
crates/extension-sdk/Cargo.lock
extensions-wasm/Cargo.lock
wasm/Cargo.lock
examples/**/Cargo.lock

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
._*
Thumbs.db
Desktop.ini
ehthumbs.db

# ── IDE / Editor ─────────────────────────────────────────────────────────────
# Personal .vscode files stay ignored; shared editor config is opted in below.
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── Local dev tooling (Cargo overrides, Claude Code state) ───────────────────
.cargo/
.claude/

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
/docs

# ── Tauri generated ──────────────────────────────────────────────────────────
apps/desktop/gen/

# ── Test / Coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Misc ─────────────────────────────────────────────────────────────────────
*.tgz
*.vsix
.turbo/
.cache/
.parcel-cache/

# ── Incomplete Rust WASM extensions (stubs, not yet LSP-backed) ──────────────
extensions-wasm/debug-auto-launch-extension/
extensions-wasm/debug-server-ready-extension/
extensions-wasm/emmet-extension/
extensions-wasm/git-extension/
extensions-wasm/grunt-extension/
extensions-wasm/gulp-extension/
extensions-wasm/html-language-extension/
extensions-wasm/jake-extension/
extensions-wasm/json-language-extension/
extensions-wasm/markdown-extension/
extensions-wasm/merge-conflict-extension/
extensions-wasm/npm-extension/
extensions-wasm/php-language-extension/
extensions-wasm/references-view-extension/
extensions-wasm/terminal-suggest-extension/

# ── Cloudflare Wrangler (marketplace-proxy dev state) ────────────────────────
infrastructure/marketplace-proxy/.wrangler/
infrastructure/marketplace-proxy/node_modules/


extensions-wasm/css-language-extension/css-data.json
extensions-wasm/css-language-extension/css-builtin.json
extensions-wasm/css-language-extension/src/css_data.rs
extensions-meta.json
apps/workbench/public/builtin-extensions.js
.superpowers/
